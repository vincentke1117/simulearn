{
  "name": "lab-transient-rc-charge（τ=1ms, 5τ 充至 4.966V）",
  "endpoint": "simulate",
  "request": {
    "components": [
      {
        "id": "V1",
        "type": "vsource_dc",
        "parameters": {
          "dc": 5.0
        },
        "connections": {
          "pos": "n1",
          "neg": "gnd"
        }
      },
      {
        "id": "R1",
        "type": "resistor",
        "parameters": {
          "value": 1000.0
        },
        "connections": {
          "p": "n1",
          "n": "n2"
        }
      },
      {
        "id": "C1",
        "type": "capacitor",
        "parameters": {
          "value": 1e-06
        },
        "connections": {
          "p": "n2",
          "n": "gnd"
        }
      },
      {
        "id": "G1",
        "type": "ground",
        "parameters": {},
        "connections": {
          "gnd": "gnd"
        }
      },
      {
        "id": "VP1",
        "type": "voltage_probe",
        "parameters": {},
        "connections": {
          "node": "n2"
        }
      }
    ],
    "nets": [
      {
        "name": "n1",
        "nodes": [
          [
            "V1",
            "pos"
          ],
          [
            "R1",
            "p"
          ]
        ]
      },
      {
        "name": "n2",
        "nodes": [
          [
            "R1",
            "n"
          ],
          [
            "C1",
            "p"
          ],
          [
            "VP1",
            "node"
          ]
        ]
      },
      {
        "name": "gnd",
        "nodes": [
          [
            "V1",
            "neg"
          ],
          [
            "C1",
            "n"
          ],
          [
            "G1",
            "gnd"
          ]
        ]
      }
    ],
    "sim": {
      "t_stop": 0.005,
      "n_samples": 101
    }
  },
  "expect": [
    {
      "path": "status",
      "equals": "ok"
    },
    {
      "path": "data.signals.1.values.-1",
      "approx": 4.966,
      "atol": 0.06
    }
  ]
}