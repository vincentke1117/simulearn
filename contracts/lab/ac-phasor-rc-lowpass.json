{
  "name": "lab-ac-phasor-rc-lowpass-cutoff",
  "endpoint": "simulate",
  "request": {
    "components": [
      {
        "id": "VAC1",
        "type": "vsource_ac",
        "parameters": { "amplitude": 5.0, "frequency": 1000.0 },
        "connections": { "pos": "n1", "neg": "gnd" }
      },
      {
        "id": "R1",
        "type": "resistor",
        "parameters": { "value": 1000.0 },
        "connections": { "p": "n1", "n": "n2" }
      },
      {
        "id": "C1",
        "type": "capacitor",
        "parameters": { "value": 1.5915494309189535e-07 },
        "connections": { "p": "n2", "n": "gnd" }
      },
      {
        "id": "G1",
        "type": "ground",
        "parameters": {},
        "connections": { "gnd": "gnd" }
      }
    ],
    "nets": [
      { "name": "n1", "nodes": [["VAC1", "pos"], ["R1", "p"]] },
      { "name": "n2", "nodes": [["R1", "n"], ["C1", "p"]] },
      { "name": "gnd", "nodes": [["VAC1", "neg"], ["C1", "n"], ["G1", "gnd"]] }
    ],
    "sim": { "t_stop": 0.001, "n_samples": 10 },
    "method": "ac_phasor"
  },
  "expect": [
    { "path": "status", "equals": "ok" },
    { "path": "method", "equals": "ac_phasor" },
    { "path": "data.frequency_hz", "approx": 1000.0, "atol": 1e-09 },
    { "path": "data.node_voltages.n1", "approx": 5.0, "atol": 1e-09 },
    { "path": "data.node_voltages.n2", "approx": 3.5355339059327378, "atol": 1e-09 },
    { "path": "data.node_phases_deg.n2", "approx": -45.0, "atol": 1e-06 },
    { "path": "data.branch_currents.R1", "approx": 0.0035355339059327377, "atol": 1e-12 },
    { "path": "data.branch_phases_deg.R1", "approx": 45.0, "atol": 1e-06 },
    { "path": "data.branch_currents.VAC1", "approx": 0.0035355339059327377, "atol": 1e-12 },
    { "path": "data.branch_phases_deg.VAC1", "approx": -135.0, "atol": 1e-06 }
  ]
}
