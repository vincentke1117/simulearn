{
  "name": "lab-control-step-gain-plant（稳态 = 1×2×1 = 2.0）",
  "endpoint": "simulate",
  "request": {
    "kind": "control",
    "blocks": [
      {
        "id": "STEP1",
        "type": "control_step",
        "parameters": {
          "amplitude": 1.0,
          "offset": 0.0,
          "startTime": 0.0
        }
      },
      {
        "id": "K1",
        "type": "control_gain",
        "parameters": {
          "gain": 2.0
        }
      },
      {
        "id": "P1",
        "type": "control_plant_1st",
        "parameters": {
          "gain": 1.0,
          "timeConstant": 0.2,
          "initialValue": 0.0
        }
      },
      {
        "id": "SCOPE1",
        "type": "control_scope",
        "parameters": {}
      }
    ],
    "edges": [
      {
        "id": "e1",
        "source": "STEP1",
        "target": "K1",
        "sourceHandle": "out",
        "targetHandle": "in"
      },
      {
        "id": "e2",
        "source": "K1",
        "target": "P1",
        "sourceHandle": "out",
        "targetHandle": "in"
      },
      {
        "id": "e3",
        "source": "P1",
        "target": "SCOPE1",
        "sourceHandle": "out",
        "targetHandle": "in"
      }
    ],
    "outputs": [
      {
        "id": "scope:SCOPE1",
        "blockId": "SCOPE1",
        "handle": "in",
        "label": "Scope SCOPE1"
      }
    ],
    "sim": {
      "t_stop": 2.0,
      "n_samples": 200
    }
  },
  "expect": [
    {
      "path": "status",
      "equals": "ok"
    },
    {
      "path": "data.signals.1.values.-1",
      "approx": 2.0,
      "atol": 0.02
    }
  ]
}